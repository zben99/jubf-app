RewriteEngine On

# Si la requête ne commence pas par /public/, on la réécrit vers /public/ en interne
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ /public/$1 [L]

# Protection des fichiers sensibles
<FilesMatch "^\.env$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(env|ini|log|json|lock|gitignore|gitattributes|htaccess|htpasswd|md)$">
    Require all denied
</FilesMatch>

# Empêcher l'accès direct aux dossiers sensibles
RedirectMatch 404 /vendor/
RedirectMatch 404 /node_modules/
